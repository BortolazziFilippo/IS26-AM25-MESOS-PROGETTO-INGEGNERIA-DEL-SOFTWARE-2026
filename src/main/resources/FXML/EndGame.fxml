<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.polimi.ingsw.am25.client.GUI.EndGameController"
            stylesheets="@EndGame.css">
    <VBox alignment="CENTER" spacing="24.0"
          AnchorPane.bottomAnchor="40.0"
          AnchorPane.leftAnchor="150.0"
          AnchorPane.rightAnchor="150.0"
          AnchorPane.topAnchor="40.0">

        <!-- Title -->
        <Label text="FINE PARTITA" styleClass="title-label">
            <font><Font name="System Bold" size="52.0"/></font>
        </Label>

        <!-- Winner section -->
        <StackPane styleClass="winner-box">
            <VBox alignment="CENTER" spacing="8.0" style="-fx-padding: 20 40 20 40;">
                <Label text="🏆" styleClass="trophy-label">
                    <font><Font size="48.0"/></font>
                </Label>
                <Label fx:id="winnersLabel" text="Vincitore: -" styleClass="winner-label">
                    <font><Font name="System Bold" size="28.0"/></font>
                </Label>
            </VBox>
        </StackPane>

        <!-- Rank -->
        <Label text="CLASSIFICA" styleClass="section-label">
            <font><Font name="System Bold" size="18.0"/></font>
        </Label>

        <TableView fx:id="rankingTable" prefHeight="200.0" maxWidth="800.0"
                   styleClass="ranking-table">
            <columns>
                <TableColumn fx:id="rankColumn"  text="#"               prefWidth="55.0"  />
                <TableColumn fx:id="nameColumn"  text="Nome"            prefWidth="230.0" />
                <TableColumn fx:id="colorColumn" text="Colore"          prefWidth="140.0" />
                <TableColumn fx:id="ppColumn"    text="Punti Prestigio" prefWidth="165.0" />
                <TableColumn fx:id="foodColumn"  text="Cibo"            prefWidth="120.0" />
            </columns>
        </TableView>

        <!--Global rank from DB-->
        <Label text="CLASSIFICA GLOBALE (storico)" styleClass="section-label">
            <font><Font name="System Bold" size="18.0"/></font>
        </Label>

        <ListView fx:id="globalLeaderboardList" prefHeight="160.0" maxWidth="800.0"
                  styleClass="global-list"/>

        <Button text="Esci dal gioco" onAction="#handleClose"
                prefWidth="240.0" prefHeight="48.0" styleClass="exit-button"/>
    </VBox>
</AnchorPane>