<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="660.0" prefWidth="520.0"
      stylesheets="@PlayerStatus.css"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1">
    <children>

        <!-- ── Title bar ───────────────────────────────────────── -->
        <HBox styleClass="status-title-bar">
            <children>
                <Label styleClass="status-title" text="STATO DEI GIOCATORI" />
                <Region HBox.hgrow="ALWAYS" />
                <Button styleClass="status-close-btn"
                        mnemonicParsing="false" onAction="#handleClose" text="Chiudi" />
            </children>
        </HBox>

        <!-- ── Leaderboard (always visible above tabs) ─────────── -->
        <VBox fx:id="leaderboardBox" style="-fx-padding: 12 16 8 16;" />

        <!-- ── One tab per player ───────────────────────────────── -->
        <TabPane fx:id="playerTabPane" tabClosingPolicy="UNAVAILABLE"
                 styleClass="player-tab-pane" VBox.vgrow="ALWAYS" />

    </children>
</VBox>
