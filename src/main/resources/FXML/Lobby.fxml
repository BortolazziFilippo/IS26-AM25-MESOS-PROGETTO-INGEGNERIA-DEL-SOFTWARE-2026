<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="720.0" spacing="18.0"
      stylesheets="@Lobby.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="32" left="40" right="40" top="32"/>
    </padding>
    <children>

        <!-- Header -->
        <VBox alignment="CENTER" spacing="2.0">
            <children>
                <Label styleClass="titolo" text="MESOS — Lobby"/>
                <Label styleClass="sottotitolo" text="prepara la tua tribù prima che il fuoco si spenga"/>
            </children>
        </VBox>

        <!--  form panel -->
        <VBox styleClass="panel" spacing="12.0">
            <children>

                <!-- Nickname + color -->
                <HBox spacing="14.0" alignment="CENTER_LEFT">
                    <children>
                        <Label styleClass="field-label" text="Nickname:"/>
                        <TextField fx:id="nicknameField" prefWidth="180" promptText="il tuo nome"/>
                        <Region prefWidth="20"/>
                        <Label styleClass="field-label" text="Colore:"/>
                        <ComboBox fx:id="colorBox" prefWidth="170"/>
                    </children>
                </HBox>

                <!-- Section new game -->
                <Label styleClass="section-divider" text="Nuova partita" maxWidth="Infinity"/>
                <Button fx:id="enterButton"
                        text="Crea partita / Unisciti"
                        onAction="#onEnter"
                        maxWidth="Infinity"/>

                <!-- Section game saved -->
                <Label styleClass="section-divider" text="Partita salvata" maxWidth="Infinity"/>
                <HBox spacing="14.0">
                    <children>
                        <Button fx:id="loadButton"
                                text="Carica partita"
                                onAction="#onLoadGame"
                                maxWidth="Infinity"
                                HBox.hgrow="ALWAYS"/>
                        <Button fx:id="joinLoadedButton"
                                text="Unisciti a caricata"
                                onAction="#onJoinLoadedGame"
                                maxWidth="Infinity"
                                HBox.hgrow="ALWAYS"/>
                    </children>
                </HBox>

                <!--Rank (Secondary bottom right)-->
                <HBox alignment="CENTER_RIGHT">
                    <children>
                        <Button fx:id="rankButton"
                                text="Classifica"
                                onAction="#onShowRank"
                                styleClass="button-secondary"/>
                    </children>
                </HBox>

            </children>
        </VBox>

        <!-- Players list -->
        <Label styleClass="section-title" text="Giocatori in lobby"/>
        <ListView fx:id="playerList" prefHeight="200.0" VBox.vgrow="ALWAYS"/>

        <!-- Status / errors -->
        <Label fx:id="label" styleClass="status" wrapText="true"/>

    </children>
</VBox>
