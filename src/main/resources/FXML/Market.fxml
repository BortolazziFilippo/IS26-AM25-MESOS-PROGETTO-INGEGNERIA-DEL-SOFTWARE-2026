<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<AnchorPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@Market.css">
    <children>

        <!-- ── Header bar ─────────────────────────────────────── -->
        <HBox fx:id="headerHBox" spacing="24"
              style="-fx-padding: 10 14 10 14; -fx-alignment: CENTER_LEFT;"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox spacing="4">
                    <children>
                        <Label fx:id="phaseLabel" text="Fase corrente: -">
                            <font>
                                <Font name="System Bold" size="14.0"/>
                            </font>
                        </Label>
                        <Label fx:id="currentPlayerLabel" text="Giocatore di turno: -">
                            <font>
                                <Font name="System Bold" size="14.0"/>
                            </font>
                        </Label>
                    </children>
                </VBox>
                <VBox spacing="4">
                    <children>
                        <Label text="Azioni disponibili:">
                            <font>
                                <Font name="System Bold" size="14.0"/>
                            </font>
                        </Label>
                        <HBox spacing="20">
                            <children>
                                <Label fx:id="drawTopLabel" text="Pesca da sopra: -">
                                    <font>
                                        <Font name="System Bold" size="14.0"/>
                                    </font>
                                </Label>
                                <Label fx:id="drawBotLabel" text="Pesca da sotto: -">
                                    <font>
                                        <Font name="System Bold" size="14.0"/>
                                    </font>
                                </Label>
                            </children>
                        </HBox>
                    </children>
                </VBox>
                <VBox spacing="4">
                    <children>
                        <Label fx:id="foodLabel" text="Cibo:">
                            <font>
                                <Font name="System Bold" size="14.0"/>
                            </font>
                        </Label>
                        <Label fx:id="prestigePointLabel" text="Punti Prestigio:">
                            <font>
                                <Font name="System Bold" size="14.0"/>
                            </font>
                        </Label>
                    </children>
                </VBox>
                <VBox spacing="4">
                    <children>
                        <Label fx:id="shamanStarLabel" text="Stelle sciamano:">
                            <font>
                                <Font name="System Bold" size="14.0"/>
                            </font>
                        </Label>
                        <Label fx:id="builderDiscountLabel" text="Sconto Costruttori:">
                            <font>
                                <Font name="System Bold" size="14.0"/>
                            </font>
                        </Label>
                    </children>
                </VBox>
                <!-- pushes buttons to the right -->
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="playerStatusButton" mnemonicParsing="false"
                        onAction="#showPlayerStatus" prefHeight="48.0" text="Stato giocatori"/>
            </children>
        </HBox>

        <!-- ── Main content (topAnchor updated at runtime by controller) ── -->
        <SplitPane fx:id="splitPane" dividerPositions="0.8"
                   AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="80.0">
            <items>
                <!-- Left: three card rows grouped and centred vertically -->
                <VBox alignment="CENTER" spacing="10" style="-fx-padding: 8;">
                    <ScrollPane fitToHeight="false" fitToWidth="false"
                                hbarPolicy="AS_NEEDED" vbarPolicy="NEVER">
                        <content>
                            <HBox fx:id="topCardHbox" spacing="10"
                                  style="-fx-padding: 8; -fx-alignment: CENTER_LEFT;"/>
                        </content>
                    </ScrollPane>
                    <ScrollPane fitToHeight="false" fitToWidth="false"
                                hbarPolicy="AS_NEEDED" vbarPolicy="NEVER">
                        <content>
                            <HBox fx:id="tileHbox" spacing="10"
                                  style="-fx-padding: 8; -fx-alignment: CENTER;"/>
                        </content>
                    </ScrollPane>
                    <ScrollPane fitToHeight="false" fitToWidth="false"
                                hbarPolicy="AS_NEEDED" vbarPolicy="NEVER">
                        <content>
                            <HBox fx:id="bottomCardHbox" spacing="10"
                                  style="-fx-padding: 8; -fx-alignment: CENTER_LEFT;"/>
                        </content>
                    </ScrollPane>
                </VBox>

                <!-- Right: action buttons -->
                <VBox alignment="CENTER" spacing="40" style="-fx-padding: 40;">
                    <children>
                        <Button fx:id="selectCardButton" maxWidth="Infinity" mnemonicParsing="false"
                                onAction="#handleSelectCard" prefHeight="80.0" text="Seleziona carta"/>
                        <Button fx:id="placeTotemButton" maxWidth="Infinity" mnemonicParsing="false"
                                onAction="#handlePlaceTotem" prefHeight="80.0" text="Posiziona totem"/>
                        <Button fx:id="skipTurnButton" maxWidth="Infinity" mnemonicParsing="false"
                                onAction="#handleSkipTurn" prefHeight="80.0" text="Salta turno"/>
                    </children>
                </VBox>
            </items>
        </SplitPane>

    </children>
</AnchorPane>
